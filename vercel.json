{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" }
      ]
    },
    {
      "source": "/feed/google.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" }
      ]
    }
  ]
}
